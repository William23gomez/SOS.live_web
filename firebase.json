{
  "functions": {
    "source": "backend",
    "runtime": "nodejs22"
  },
  "hosting": {
    "public": "sos.live-frontend/dist/sos.live-frontend/browser",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api{,/**}",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
